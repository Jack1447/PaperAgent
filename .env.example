# ============================================================
# PaperAgent 配置文件
# 使用方法: 复制此文件为 .env，填入你的 API Key
# ============================================================

# ============================================================
# PaperAgent 配置文件
# ============================================================

# ========== 主模型配置 (Summarize / Reading / Review) ==========
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-
LLM_BASE_URL=https://api.302.ai/v1

# ========== 快速模型配置 (Planner / Search / Reflection / Translate) ==========
FAST_LLM_MODEL=gpt-4o-mini
FAST_LLM_API_KEY=sk-
FAST_LLM_BASE_URL=https://api.302.ai/v1

# ========== Embedding 配置 (论文 chunk 语义检索) ==========
# 默认复用主 LLM 的 Key/BaseURL，可单独覆盖；默认模型 BAAI/bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_API_KEY=sk-
# EMBEDDING_BASE_URL=https://api.302.ai/v1

# ========== 搜索数据源配置 ==========
# arXiv 免费，无需 API Key

# SerpAPI Scholar (通过 302.ai)
SCHOLAR_API_KEY=sk-
SCHOLAR_BASE_URL=https://api.302.ai/serpapi/search

# translate 
TRANSLATE_API_KEY=sk-
TRANSLATE_BASE_URL=https://api.302.ai/v1/chat/completions

# ========== 界面语言 (zh / en) ==========
LANGUAGE=zh
